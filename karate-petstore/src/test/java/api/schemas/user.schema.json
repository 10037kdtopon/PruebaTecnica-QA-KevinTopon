{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "required": ["username", "email"],
  "properties": {
    "id": { "type": "integer" },
    "username": { "type": "string", "minLength": 1 },
    "firstName": { "type": "string" },
    "lastName": { "type": "string" },
    "email": { "type": "string" },
    "password": { "type": "string" },
    "phone": { "type": "string" },
    "userStatus": { "type": "integer" }
  }
}
